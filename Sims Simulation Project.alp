				<Event>
					<Id>1768310322324</Id>
					<Name><![CDATA[School_Call]]></Name>
					<X>440</X><Y>640</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="rate" Mode="occuresOnce">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1.0/7.0 // per day]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_DAY]]></Unit>
						</Rate>
						<Id>1768310322322</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1768377600000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[if (!familyActive) return;

//traceln("School call at t=" + time() + " Son_Mood=" + Son_Mood);
if (Son_Mood == -10) {
    Savings = Savings - 70;
    totalSchoolDamageCost += 70;
}

]]></Action>
				</Event>
				<Event>
					<Id>1768311862883</Id>
					<Name><![CDATA[Employment_Tick]]></Name>
					<X>440</X><Y>600</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_DAY]]></Unit>
						</Rate>
						<Id>1768311862881</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1768377600000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[if (!familyActive) return;

if (!Is_Employed) {
    totalUnemploymentDays += 1;
}

// traceln(
//  "TICK t=" + time() +
//  " employed=" + Is_Employed +
//  " daysLeft=" + daysToNextStateDecision
//);

// daily countdown
daysToNextStateDecision -= 1;

// not time yet
if (daysToNextStateDecision >= 1) return;

// ===== EMPLOYMENT STATE CHANGE =====
if (Is_Employed) {
    // job ends
    Is_Employed = false;
    Income_Per_Day = 5;

    // after finishing one job he immediately finds a new one with prob 0.8
    if (randomTrue(0.8)) {
        Is_Employed = true;
        Income_Per_Day = 15;

        // draw next employment duration from samples
        daysToNextStateDecision =
            EmploymentSamples[ uniform_discr(0, EmploymentSamples.length - 1) ];
    } else {
        // unemployed for 5–15 days
        daysToNextStateDecision = uniform(5, 15);
    }

} else {
    // unemployment ends
    if (randomTrue(0.6)) {
        Is_Employed = true;
        Income_Per_Day = 15;

        // draw next employment duration from samples
        daysToNextStateDecision =
            EmploymentSamples[ uniform_discr(0, EmploymentSamples.length - 1) ];
    } else {
        // remain unemployed another 5–15 days
        daysToNextStateDecision = uniform(5, 15);
    }
}

//traceln(
//  "EMP CHANGE at t=" + time() +
//  " employed=" + Is_Employed +
//  " nextChangeIn=" + daysToNextStateDecision
//);]]></Action>
				</Event>
				<Event>
					<Id>1768386562819</Id>
					<Name><![CDATA[Check_Ending]]></Name>
					<X>440</X><Y>560</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_DAY]]></Unit>
						</Rate>
						<Id>1768386562817</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1768464000000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[if (!familyActive) return;

// use your stock values directly (they behave like doubles in actions)
double mom = Mom_Mood;
double dad = Dad_Mood;
double sav = Savings;

// Bankruptcy first (as per assignment)
if (sav < -500) {
    broke = true;
    familyActive = false;
    endDay = time();
    endReason = "BROKE (Savings < -500)";
    endMomMood = mom;
    endDadMood = dad;
    endSavings = sav;
    endSchoolDamageCost = totalSchoolDamageCost;
    endUnemploymentDays = totalUnemploymentDays;
    endEmploymentDays = endDay - totalUnemploymentDays;
    AvgMomMood = sumMomMood / endDay;
	AvgDadMood = sumDadMood / endDay;
	AvgSonMood = sumSonMood / endDay;
	endAvgSavings = sumSavings / endDay;
    
    // Add to Dataset
    ds_unemploymentDays.add( endUnemploymentDays );
	ds_schoolDamageCost.add( endSchoolDamageCost );
	ds_endSavings.add( endSavings );
	ds_endDay.add( endDay );
    return;
}

// Divorce rule
if (mom < 0 && dad < 0) {
    divorced = true;
    familyActive = false;
    endDay = time();
    endReason = "DIVORCE (Mom < 0 AND Dad < 0)";
    endMomMood = mom;
    endDadMood = dad;
    endSavings = sav;
    endSchoolDamageCost = totalSchoolDamageCost;
    endUnemploymentDays = totalUnemploymentDays;
    endEmploymentDays = endDay - totalUnemploymentDays;
    AvgMomMood = sumMomMood / endDay;
	AvgDadMood = sumDadMood / endDay;
	AvgSonMood = sumSonMood / endDay;
	endAvgSavings = sumSavings / endDay;
    
    //Add to Dataset
    ds_unemploymentDays.add( endUnemploymentDays );
	ds_schoolDamageCost.add( endSchoolDamageCost );
	ds_endSavings.add( endSavings );
	ds_endDay.add( endDay );
    return;
}]]></Action>
				</Event>
			</Events>
