		<!--   =========  Parameter Variation Experiment   ========  -->
		<ParamVariationExperiment ActiveObjectClassId="1768239193419">
			<Id>1768396655602</Id>
			<Name><![CDATA[MC_OneYear_NoInterventions]]></Name>
			<AdditionalClassCode><![CDATA[int N = 0;

int countBroke = 0;
int countDivorced = 0;
int countNone = 0;

double sumUnemploymentDays = 0;
double sumEmploymentDays = 0;
double sumSchoolDamageCost = 0;
double sumEndSavings = 0;
double sumEndDay = 0;

double sumAvgMomMood = 0;
double sumAvgDadMood = 0;
double sumAvgSonMood = 0;

double sumAvgSavings = 0;]]></AdditionalClassCode>
			<CommandLineArguments><![CDATA[]]></CommandLineArguments>
			<MaximumMemory>512</MaximumMemory>
			<RandomNumberGenerationType>randomSeed</RandomNumberGenerationType>
			<CustomGeneratorCode>new Random()</CustomGeneratorCode>
			<BeforeEachExperimentRunCode><![CDATA[N = 0;
countBroke = 0;
countDivorced = 0;
countNone = 0;

sumUnemploymentDays = 0;
sumEmploymentDays = 0;
sumSchoolDamageCost = 0;
sumEndSavings = 0;
sumEndDay = 0;

sumAvgMomMood = 0;
sumAvgDadMood = 0;
sumAvgSonMood = 0;

sumAvgSavings = 0;]]></BeforeEachExperimentRunCode>
			<AfterSimulationRunCode><![CDATA[Main m = (Main) root;

N++;

if (m.broke) countBroke++;
if (m.divorced) countDivorced++;
if (!m.broke && !m.divorced) countNone++;

// SUMS
sumUnemploymentDays += m.endUnemploymentDays;
sumEmploymentDays += m.endEmploymentDays;
sumSchoolDamageCost += m.totalSchoolDamageCost;
sumEndSavings        += m.endSavings; 
sumEndDay            += m.endDay;           // day of termination or 365
sumAvgMomMood += m.AvgMomMood;
sumAvgDadMood += m.AvgDadMood;
sumAvgSonMood += m.AvgSonMood;
sumAvgSavings += m.endAvgSavings;

traceln("RUN " + N +
        " broke=" + countBroke +
        " divorced=" + countDivorced +
        " none=" + countNone);
 ]]></AfterSimulationRunCode>
			<SeedValue>1</SeedValue>
			<SelectionModeForSimultaneousEvents>LIFO</SelectionModeForSimultaneousEvents>
			<VmArgs><![CDATA[]]></VmArgs>
			<LoadRootFromSnapshot>false</LoadRootFromSnapshot>

			<Presentation>
