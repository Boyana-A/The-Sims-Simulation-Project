			<AfterExperimentCode><![CDATA[double pBroke = (double) countBroke / N;
double pDiv   = (double) countDivorced / N;
double pNone  = (double) countNone / N;

double avgUnemp = sumUnemploymentDays / N;
double avgEmp = sumEmploymentDays / N;
double avgSchool = sumSchoolDamageCost / N;
double avgEndSavings = sumEndSavings / N;
double avgEndDay = sumEndDay / N;

double z = 1.96; // 95% CI

double ciBroke = z * Math.sqrt(pBroke * (1 - pBroke) / N);
double ciDiv   = z * Math.sqrt(pDiv   * (1 - pDiv)   / N);
double ciNone  = z * Math.sqrt(pNone  * (1 - pNone)  / N);

traceln("===== ONE-YEAR MONTE CARLO RESULTS =====");
traceln("Runs: " + N);
traceln("P(BROKE)    = " + pBroke + " ± " + ciBroke);
traceln("P(DIVORCED) = " + pDiv   + " ± " + ciDiv);
traceln("P(NONE)     = " + pNone  + " ± " + ciNone);

System.out.println("AVG unemployment days = " + avgUnemp);
System.out.println("AVG employment days = " + avgEmp);
System.out.println("AVG school damage cost = " + avgSchool);
System.out.println("AVG end savings = " + avgEndSavings);
System.out.println("AVG end day = " + avgEndDay);
System.out.println("AVG Mom mood = " + sumAvgMomMood / N);
System.out.println("AVG Dad mood = " + sumAvgDadMood / N);
System.out.println("AVG Son mood = " + sumAvgSonMood / N);
System.out.println("AVG savings over time = " + sumAvgSavings / N);
]]></AfterExperimentCode>
